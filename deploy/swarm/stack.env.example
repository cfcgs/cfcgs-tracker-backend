STACK_NAME=cfcgs
DOMAIN=cfcgs-tracker.duckdns.org
ACME_EMAIL=seu-email@exemplo.com

BACKEND_IMAGE=seu-dockerhub/cfcgs-tracker-backend:latest
FRONTEND_IMAGE=seu-dockerhub/cfcgs-tracker-frontend:latest

DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=cfcgs_db

EXPECTED_COLUMNS=year,project_title,beneficiary_country
SIMILARITY_THRESHOLD=80
REGIONS=
GEMINI_API_KEY=
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
INITIAL_ADMIN_USERNAME=
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=
CHATBOT_RATE_LIMIT_REQUESTS=30
CHATBOT_RATE_LIMIT_WINDOW_SECONDS=60
CHATBOT_RATE_LIMIT_ENABLED=true
HEATMAP_DYNAMIC_FILTERS_ENABLED=false
